<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/gradient_background_light">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="8dp"
        app:cardCornerRadius="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Добавление подписки"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:layout_marginBottom="24dp"/>

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Название подписки"
                android:inputType="text"
                android:padding="16dp"
                android:background="@drawable/edittext_background"
                android:textColor="#333333"
                android:textColorHint="#999999"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/etPrice"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Цена в месяц (₽)"
                android:inputType="numberDecimal"
                android:padding="16dp"
                android:background="@drawable/edittext_background"
                android:textColor="#333333"
                android:textColorHint="#999999"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/etCategory"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="Категория"
                android:inputType="text"
                android:padding="16dp"
                android:background="@drawable/edittext_background"
                android:textColor="#333333"
                android:textColorHint="#999999"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Период подписки"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/etStartDate"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:hint="Дата начала"
                    android:inputType="none"
                    android:padding="16dp"
                    android:background="@drawable/edittext_background"
                    android:textColor="#333333"
                    android:textColorHint="#999999"
                    android:layout_marginEnd="8dp"
                    android:focusable="false"
                    android:clickable="true"/>

                <EditText
                    android:id="@+id/etEndDate"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:hint="Дата окончания"
                    android:inputType="none"
                    android:padding="16dp"
                    android:background="@drawable/edittext_background"
                    android:textColor="#333333"
                    android:textColorHint="#999999"
                    android:layout_marginStart="8dp"
                    android:focusable="false"
                    android:clickable="true"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnSave"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="СОХРАНИТЬ"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/button_background"
                    android:layout_marginEnd="8dp"
                    android:elevation="4dp"/>

                <Button
                    android:id="@+id/btnCancel"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="ОТМЕНА"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/button_background_red"
                    android:layout_marginStart="8dp"
                    android:elevation="4dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>